{
  "name": "react-mono-core",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "format": "turbo format",
    "typecheck": "turbo typecheck",
    "generate": "turbo run generate",
    "update-shadcn": "pnpm dlx shadcn@latest add -c packages/web-ui --all --overwrite",
    "outdated-deps": "pnpm outdated -r",
    "update-deps": "pnpm update -r --interactive --latest",
    "dedupe-deps": "pnpm dedupe -r"
  },
  "devDependencies": {
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "prettier": "catalog:",
    "prettier-plugin-tailwindcss": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:"
  },
  "packageManager": "pnpm@11.5.1",
  "engines": {
    "node": "26.2.0",
    "pnpm": "11.5.1"
  }
}
