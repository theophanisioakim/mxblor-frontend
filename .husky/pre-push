# Pre-push gate — runs the CI "check" job's read-only checks, including the web
# E2E suite (see .github/workflows/ci.yml). Bypass in an emergency with
# `git push --no-verify` (discouraged — CI still runs its own gate).
echo "[pre-push] dependency hygiene (sherif)…"
pnpm lint:deps

echo "[pre-push] biome (format · lint · assist, zero warnings)…"
pnpm biome:ci

echo "[pre-push] typecheck…"
pnpm typecheck

echo "[pre-push] test…"
pnpm test

echo "[pre-push] expo doctor (native)…"
pnpm doctor:native

echo "[pre-push] build…"
pnpm build

echo "[pre-push] web e2e…"
pnpm --filter web test:e2e

echo "[pre-push] OK"
