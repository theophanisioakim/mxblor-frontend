{
  "$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "**",
      "!**/node_modules",
      "!**/dist",
      "!**/dist-verify",
      "!**/build",
      "!**/.next",
      "!**/.turbo",
      "!**/.expo",
      "!**/coverage",
      "!**/*-env.d.ts",
      "!apps/native/android",
      "!apps/native/ios",
      "!apps/native/scripts",
      "!packages/api-client/openapi.json"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 80,
    "lineEnding": "lf"
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "javascript": {
    "formatter": {
      "semicolons": "asNeeded",
      "quoteStyle": "double",
      "jsxQuoteStyle": "double",
      "trailingCommas": "es5",
      "arrowParentheses": "always"
    }
  },
  "json": {
    "formatter": {
      "enabled": true
    }
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    },
    "formatter": {
      "enabled": false
    },
    "linter": {
      "enabled": false
    }
  },
  "linter": {
    "enabled": true,
    "domains": {
      "react": "recommended"
    },
    "rules": {
      "recommended": true,
      "suspicious": {
        "noUnknownAtRules": "off"
      },
      "style": {
        "noRestrictedImports": {
          "level": "error",
          "options": {
            "patterns": [
              {
                "group": [
                  "@workspace/web-ui",
                  "@workspace/web-ui/*",
                  "@workspace/native-ui",
                  "@workspace/native-ui/*"
                ],
                "message": "Import UI through @workspace/ui — web-ui (shadcn) and native-ui (rnr) are private to the @workspace/ui abstraction layer (AGENTS.md §2)."
              }
            ]
          }
        }
      },
      "nursery": {
        "useSortedClasses": {
          "level": "warn",
          "options": {
            "functions": ["cn", "cva", "clsx"]
          }
        }
      }
    }
  },
  "overrides": [
    {
      "includes": ["packages/ui/**"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": "off"
          }
        }
      }
    },
    {
      "includes": ["packages/web-ui/**"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": ["@workspace/native-ui", "@workspace/native-ui/*"],
                    "message": "web-ui must not import native-ui — both are private to @workspace/ui (AGENTS.md §2)."
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "includes": ["packages/native-ui/**"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": ["@workspace/web-ui", "@workspace/web-ui/*"],
                    "message": "native-ui must not import web-ui — both are private to @workspace/ui (AGENTS.md §2)."
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "includes": [
        "packages/web-ui/src/components/**",
        "packages/native-ui/src/components/**"
      ],
      "linter": {
        "enabled": false
      }
    },
    {
      "includes": ["packages/api-client/src/generated/**"],
      "linter": {
        "enabled": false
      }
    }
  ]
}
