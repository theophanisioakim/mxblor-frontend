{
  "name": "react-mono-core",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "prepare": "husky",
    "build": "turbo build",
    "dev": "turbo dev",
    "test": "turbo test",
    "test:e2e": "turbo test:e2e",
    "lint": "biome lint .",
    "lint:strict": "biome lint --error-on-warnings .",
    "lint:deps": "sherif -r unordered-dependencies",
    "format": "biome check --write --unsafe .",
    "format:check": "biome format .",
    "biome:ci": "biome ci --error-on-warnings .",
    "typecheck": "turbo typecheck",
    "generate": "turbo run generate",
    "check:all": "pnpm generate && pnpm format && pnpm lint:deps && pnpm typecheck && pnpm lint:strict && pnpm test && pnpm build",
    "shadcn-update": "pnpm dlx shadcn@latest add -c packages/web-ui --all --overwrite",
    "rnr-update": "pnpm dlx @react-native-reusables/cli@latest add -c packages/native-ui --all --overwrite",
    "outdated-deps": "pnpm outdated -r",
    "update-deps": "pnpm update -r --interactive --latest",
    "dedupe-deps": "pnpm dedupe -r"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@workspace/typescript-config": "workspace:*",
    "husky": "catalog:",
    "lint-staged": "catalog:",
    "sherif": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,jsonc}": "biome check --write --no-errors-on-unmatched"
  },
  "packageManager": "pnpm@11.5.2",
  "engines": {
    "node": "26.2.0",
    "pnpm": "11.5.2"
  }
}
