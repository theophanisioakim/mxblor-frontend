{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(pnpm install:*)",
      "Bash(pnpm build:*)",
      "Bash(pnpm lint:*)",
      "Bash(pnpm format:*)",
      "Bash(pnpm typecheck:*)",
      "Bash(pnpm generate:*)",
      "Bash(pnpm check:all)",
      "Bash(pnpm --filter:*)",
      "Bash(pnpm outdated:*)",
      "Bash(pnpm dedupe:*)",
      "PowerShell(pnpm:*)",
      "Bash(turbo:*)",
      "Bash(biome:*)",
      "Bash(npx biome:*)",
      "PowerShell(biome:*)",
      "PowerShell(npx biome:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git add:*)",
      "Bash(git stash:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "PowerShell(git status:*)",
      "PowerShell(git diff:*)",
      "PowerShell(git log:*)",
      "Read",
      "Grep",
      "Glob"
    ],
    "deny": [
      "Bash(pnpm dev:*)",
      "Bash(pnpm run dev:*)",
      "Bash(turbo dev:*)",
      "Bash(pnpm --filter web dev:*)",
      "Bash(pnpm --filter native start:*)",
      "Bash(pnpm --filter native prebuild:*)",
      "Bash(pnpm --filter native android:*)",
      "Bash(pnpm --filter native ios:*)",
      "Bash(pnpm test:e2e:*)",
      "Bash(pnpm --filter web test:e2e:*)",
      "Bash(pnpm --filter native test:e2e:*)",
      "Bash(turbo test:e2e:*)",
      "PowerShell(pnpm dev:*)",
      "PowerShell(pnpm run dev:*)",
      "PowerShell(pnpm --filter web dev:*)",
      "PowerShell(pnpm --filter native start:*)",
      "PowerShell(pnpm test:e2e:*)",
      "PowerShell(pnpm --filter native test:e2e:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -fdx:*)",
      "Bash(rm -rf:*)",
      "Bash(git commit --no-verify:*)",
      "Bash(git push --no-verify:*)",
      "PowerShell(Remove-Item -Recurse -Force:*)",
      "Read(./**/*.env)",
      "Read(./**/*.env.*)",
      "Read(./**/secrets/**)"
    ],
    "ask": [
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(pnpm shadcn-update:*)",
      "Bash(pnpm rnr-update:*)",
      "PowerShell(pnpm shadcn-update:*)",
      "PowerShell(pnpm rnr-update:*)",
      "PowerShell(git commit:*)",
      "PowerShell(git push:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node .agents/hooks/guard-protected-paths.mjs"
          }
        ]
      }
    ]
  }
}
