{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "check:all",
      "type": "shell",
      "command": "pnpm check:all",
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "build",
      "type": "shell",
      "command": "pnpm build",
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "typecheck",
      "type": "shell",
      "command": "pnpm typecheck",
      "problemMatcher": ["$tsc"]
    },
    {
      "label": "lint",
      "type": "shell",
      "command": "pnpm lint:strict",
      "problemMatcher": []
    },
    {
      "label": "format",
      "type": "shell",
      "command": "pnpm format",
      "problemMatcher": []
    },
    {
      "label": "test",
      "type": "shell",
      "command": "pnpm test",
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "generate",
      "type": "shell",
      "command": "pnpm generate",
      "problemMatcher": []
    },
    {
      "label": "web: dev",
      "type": "shell",
      "command": "pnpm --filter web dev",
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "native: start",
      "type": "shell",
      "command": "pnpm --filter native start",
      "isBackground": true,
      "problemMatcher": []
    }
  ]
}
